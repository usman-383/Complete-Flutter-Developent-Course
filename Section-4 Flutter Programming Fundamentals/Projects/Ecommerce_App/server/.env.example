# Copy to .env and set your Stripe secret key and SMTP credentials
STRIPE_SECRET_KEY=
PORT=3000

# SMTP (for order confirmation emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=orders@yourshop.example

# Admin basic auth
ADMIN_USER=admin
ADMIN_PASS=changeme
ADMIN_EMAIL=ops@example.com
# When a queued email fails this many times, send an admin alert
ALERT_THRESHOLD=3
